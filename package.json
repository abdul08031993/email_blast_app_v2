{
  "name": "email-blast-pro",
  "version": "1.0.1",
  "description": "Professional Email Blast Desktop Application",
  "main": "main.js",
  "author": {
    "name": "Harmedia",
    "email": "admin@harmedia.id"
  },
  "license": "ISC",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --no-sandbox --dev",
    "dist-win": "electron-builder --win --x64",
    "dist-mac": "electron-builder --mac",
    "dist-linux": "electron-builder --linux",
    "dist-all": "electron-builder -mwl"
  },
  "keywords": [
    "email",
    "blast",
    "marketing"
  ],
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "node-machine-id": "^1.1.12",
    "nodemailer": "^6.10.1",
    "puppeteer": "^21.11.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.harmedia.emailblastpro",
    "productName": "Email Blast Pro",
    "copyright": "Copyright © 2026 Harmedia",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.github/**",
      "!.git/**",
      "!**/*.md",
      "!**/node_modules/puppeteer/.local-chromium/**",
      "!**/node_modules/puppeteer/.local-browsers/**",
      "!**/node_modules/electron/**",
      "!**/node_modules/electron-builder/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "shortcutName": "Email Blast Pro"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Email Blast Pro",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Office",
      "maintainer": "Harmedia <admin@harmedia.id>"
    },
    "deb": {
      "depends": [
        "libgbm1",
        "libnss3",
        "libatk-bridge2.0-0",
        "libgtk-3-0",
        "libxss1"
      ]
    }
  }
}
