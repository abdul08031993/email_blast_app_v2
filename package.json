{
  "name": "email-blast-app",
  "version": "1.0.0",
  "description": "Professional Email Blast Desktop Application",
  "main": "main.js",
  "author": "Email Blast Pro",
  "license": "ISC",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --no-sandbox --dev",
    "dist": "electron-builder --win --x64"
  },
  "keywords": [
    "email",
    "blast",
    "marketing"
  ],
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "node-machine-id": "^1.1.12",
    "nodemailer": "^6.10.1",
    "puppeteer": "^21.11.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.harmed.emailblastpro",
    "productName": "Email Blast Pro",
    "copyright": "Copyright © 2026 Harmedia",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!.github/*",
      "!.git/*",
      "!node_modules/electron/*",
      "!node_modules/electron-builder/*"
    ]
  }
}